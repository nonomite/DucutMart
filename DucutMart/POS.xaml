<Window x:Class="DucutMart.POS"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DucutMart"
        mc:Ignorable="d"
        Title="POS" Height="750" Width="1300" WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid x:Name="gridParent" Style="{DynamicResource DashboardStyle}">
        <StackPanel Orientation="Vertical">
            <StackPanel>
                <Grid>
                    <Rectangle Style="{DynamicResource rectangleBG}" HorizontalAlignment="Stretch" Margin="0,20,0,0"/>
                    <TextBlock x:Name="welcome" Text="Welcome Back! Username" Style="{DynamicResource header}" Margin="50,20,0,0"/>
                    <TextBlock x:Name="logout" Text="Logout" Style="{DynamicResource logout}" HorizontalAlignment="Right" Margin="0,20,50,0" MouseDown="logout_MouseDown"/>
                </Grid>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
