<Application x:Class="DucutMart.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:DucutMart"
             StartupUri="Inventory.xaml">
    <Application.Resources>
        <ResourceDictionary>
           
            <!-- Background Color-->
            <SolidColorBrush x:Key="LeftBgColor" Color="#004aad"/>
            <SolidColorBrush x:Key="RightBgColor" Color="#fdf8f0" />
            <FontFamily x:Key="MainFont">Tahoma</FontFamily>

            <!--Font Styles-->
            <Style x:Key="TitleFont" TargetType="TextBlock">
                <Setter Property="FontSize" Value="24"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="FontFamily" Value="{DynamicResource MainFont}"/>
            </Style>

            <Style x:Key="BodyFont" TargetType="TextBlock">
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="FontWeight" Value="Normal"/>
                <Setter Property="FontFamily" Value="{DynamicResource MainFont}"/>
            </Style>




            <!-- Textboxes-->
            <Style x:Key="Textboxes" TargetType="TextBox">
                <Setter Property="FontFamily" Value="Tahoma"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Width" Value="300"/>
                <Setter Property="Height" Value="30"/>
            </Style>

            <!-- Labels-->
            <Style x:Key="Labels" TargetType="Label">
                <Setter Property="FontFamily" Value="{DynamicResource MainFont}"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="Gray"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>

            <!--Dashboard Styles-->
            <Style x:Key="DashboardStyle" TargetType="Grid">
                <Setter Property="Background" Value="DarkGray"/>
            </Style>

            <Style x:Key="borderDesign" TargetType="Border">
                <Setter Property="BorderBrush" Value="Black"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="InventoryStyles.xaml"/>
                <ResourceDictionary Source="DashboardStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>


        </ResourceDictionary>
    </Application.Resources>
</Application>
