<Window x:Class="DucutMart.Inventory"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DucutMart"
        mc:Ignorable="d"
        Title="Inventory" Height="900" Width="1350" WindowStartupLocation="CenterScreen">
    <Grid x:Name="gridParent" Style="{DynamicResource DashboardStyle}">
        
        <StackPanel x:Name="parentStack" Width="1300" Height="850" VerticalAlignment="Top" Margin="0,10,0,0" >
            <StackPanel x:Name="headerStack">
                <Grid Style="{DynamicResource headerGrid}" Width="1300" Height="35">
                    <TextBlock x:Name="welcome" Text="welcome" Style="{DynamicResource header}" Margin="50,0,0,0"/>
                    <TextBlock x:Name="logout" Text="Logout" Style="{DynamicResource logout}" Margin="0,0,50,0" MouseDown="logout_MouseDown" HorizontalAlignment="Right"/>
                    <Border BorderBrush="Black" BorderThickness="1"/>
                </Grid>
            </StackPanel>

            <StackPanel>
                <TabControl x:Name="tabControl" Height="800" Width="1300" Margin="0,10,0,0" Style="{DynamicResource tabDesign}">
                    
                    <TabItem Header="POS" Style="{DynamicResource tabItemDesign}">
                        <Grid Background="WhiteSmoke"/>
                    </TabItem>
                    
                    <TabItem Header="Inventory" Style="{DynamicResource tabItemDesign}">

                        <StackPanel>
                            
                            <StackPanel Width="900" Height="30" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="0,0,0,0">
                                <TextBlock Style="{DynamicResource TitleFont}" Margin="10,0,0,0" Text="Product Inventory" />
                            </StackPanel>
                            
                            <Separator Width="900" Margin="10,5,0,0" HorizontalAlignment="Left" Background="Black"/>
                            
                            <StackPanel Orientation="Horizontal" Margin="10,0,0,0" >
                                <StackPanel x:Name="leftStack" HorizontalAlignment="Left" Width="900">

                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <StackPanel Margin="0,0,20,0">
                                            <Grid Style="{DynamicResource CardDesign}">
                                                <TextBlock Text="Low Stock Products"/>
                                                <Border BorderBrush="Black" BorderThickness="1"/>
                                            </Grid>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,20,0">
                                            <Grid Style="{DynamicResource CardDesign}">
                                                <TextBlock Text="Near Expiry Products"/>
                                                <Border BorderBrush="Black" BorderThickness="1"/>
                                            </Grid>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,20,0">
                                            <Grid Style="{DynamicResource CardDesign}">
                                                <TextBlock Text="Low Stock Product"/>
                                                <Border BorderBrush="Black" BorderThickness="1"/>
                                            </Grid>
                                        </StackPanel>

                                    </StackPanel>

                                    <StackPanel x:Name="dataGridStack" Margin="0,10,0,0">
                                        <Grid Style="{DynamicResource GridDesign}">
                                            <StackPanel>
                                                <StackPanel VerticalAlignment="Top">
                                                    <DataGrid x:Name="dataGrid" IsReadOnly="True"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <Border BorderBrush="Black" BorderThickness="1"/>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel x:Name="RightStack" Margin="10,10,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Height="660" Width="340">
                                    <StackPanel>
                                        <Button Content="Add Stock Batch" Style="{DynamicResource AddButton}" HorizontalAlignment="Center" Margin="0,15,0,0"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,15,0,0">
                                        <GroupBox Style="{DynamicResource EditGrid}">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Style="{DynamicResource SelectedItemText}" Text="Batch Code:"/>
                                                    <TextBox Style="{DynamicResource SelectedItemTextBox}"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Style="{DynamicResource SelectedItemText}" Text="Batch Code:"/>
                                                    <TextBox Style="{DynamicResource SelectedItemTextBox}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </GroupBox>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                   
                    </TabItem>

                </TabControl>
            </StackPanel>
            
           
            
  
            
         
        </StackPanel>
       


